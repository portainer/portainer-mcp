# Copy to .env and fill in. Used by `make dev`.

# Required
PORTAINER_URL=https://portainer.example.com
PORTAINER_API_KEY=ptr_xxxxxxxxxxxxxxxx
# Required when PORTAINER_MCP_TRANSPORT=http (and therefore for `make dev`).
# Generate with: openssl rand -hex 32
PORTAINER_MCP_AUTH_TOKEN=

# Optional — see README for the full list.
# Defaults to stdio. `make dev` forces http; set this only if you invoke the
# server directly with `uv run --env-file .env portainer-mcp`.
# PORTAINER_MCP_TRANSPORT=http
# PORTAINER_TLS_VERIFY=0
# PORTAINER_PROFILES=ALL
# PORTAINER_MCP_LOG_LEVEL=DEBUG
